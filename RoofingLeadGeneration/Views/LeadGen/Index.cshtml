@using RoofingLeadGeneration.Data.Models
@{
    Layout = null;
    var campaigns  = ViewBag.Campaigns  as List<LeadGenCampaign>  ?? new();
    var leads      = ViewBag.Leads      as List<LeadGenLead>      ?? new();
    var targets    = ViewBag.Targets    as List<LeadGenTarget>    ?? new();
    var suppressed = (int)(ViewBag.Suppressed ?? 0);

    string StatusBadge(string s) => s switch {
        "new"       => "bg-blue-500/15 text-blue-400 border-blue-500/20",
        "available" => "bg-green-500/15 text-green-400 border-green-500/20",
        "sold"      => "bg-purple-500/15 text-purple-400 border-purple-500/20",
        "expired"   => "bg-slate-700 text-slate-500 border-slate-600",
        "draft"     => "bg-yellow-500/15 text-yellow-400 border-yellow-500/20",
        "sending"   => "bg-orange-500/15 text-orange-400 border-orange-500/20",
        "complete"  => "bg-green-500/15 text-green-400 border-green-500/20",
        _           => "bg-slate-700 text-slate-400 border-slate-600"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lead Gen Dashboard — Internal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                brand: { DEFAULT: '#f97316', dark: '#ea6c0a' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body class="min-h-screen bg-[#0f172a] text-slate-200">

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14">
        <div class="flex items-center gap-3">
            <div class="w-7 h-7 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-bolt text-white text-xs"></i>
            </div>
            <span class="font-extrabold tracking-tight">Lead Gen <span class="text-brand">Dashboard</span></span>
            <span class="text-xs text-slate-500 font-medium px-2 py-0.5 rounded-full bg-slate-800 border border-slate-700">Internal Only</span>
        </div>
        <div class="flex items-center gap-4 text-xs text-slate-400">
            <span><i class="fa-solid fa-ban mr-1 text-red-400"></i>@suppressed suppressed</span>
            <form method="post" action="/LeadGen/ClearContactHistory" class="inline"
                  onsubmit="return confirm('Clear ALL contact history? This resets all 30-day cooldowns.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-slate-500 hover:text-yellow-400 transition-colors" title="Clear all contact history (dev)">
                    <i class="fa-solid fa-clock-rotate-left"></i> clear cooldowns
                </button>
            </form>
            <a href="/Admin" class="hover:text-white transition-colors">Admin</a>
            <a href="/" class="hover:text-white transition-colors">StormLead</a>
        </div>
    </div>
</header>

<main class="max-w-7xl mx-auto px-6 py-8 space-y-10">

    @if (TempData["Success"] != null) {
    <div class="bg-green-500/10 border border-green-500/30 text-green-300 rounded-xl px-5 py-3 text-sm flex items-center gap-2">
        <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
    </div>
    }
    @if (TempData["Error"] != null) {
    <div class="bg-red-500/10 border border-red-500/30 text-red-300 rounded-xl px-5 py-3 text-sm flex items-center gap-2">
        <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]
    </div>
    }

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        @{
            var totalSent      = campaigns.Sum(c => c.TotalSent);
            var totalResponded = campaigns.Sum(c => c.TotalResponded);
            var newLeads       = leads.Count(l => l.Status == "new");
        }
        <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-4">
            <div class="text-2xl font-bold text-white">@campaigns.Count</div>
            <div class="text-xs text-slate-400 mt-0.5">Campaigns</div>
        </div>
        <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-4">
            <div class="text-2xl font-bold text-white">@totalSent</div>
            <div class="text-xs text-slate-400 mt-0.5">SMS Sent</div>
        </div>
        <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-4">
            <div class="text-2xl font-bold text-brand">@totalResponded</div>
            <div class="text-xs text-slate-400 mt-0.5">Warm Leads</div>
        </div>
        <div class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-4">
            <div class="text-2xl font-bold text-blue-400">@newLeads</div>
            <div class="text-xs text-slate-400 mt-0.5">New (unreviewed)</div>
        </div>
    </div>

    <!-- Create Campaign -->
    <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-plus mr-1.5 text-brand"></i>New Campaign
        </h2>
        <form method="post" action="/LeadGen/CreateCampaign" id="campaignForm"
              class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-5 space-y-4">
            @Html.AntiForgeryToken()

            <!-- Row 1: State / Storm Date / Hail Size / Radius / Notes -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">State</label>
                    <select name="stateAbbr" class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none">
                        <option value="TX">TX</option>
                        <option value="OK">OK</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Storm Date</label>
                    <input type="date" name="stormDate" required
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Hail Size (in)</label>
                    <input type="number" name="hailSizeInches" step="0.25" min="0.75" max="5" value="1.0" required
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Radius (mi)</label>
                    <input type="number" name="radiusMiles" step="1" min="1" max="100" value="15" required
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Notes (optional)</label>
                    <input type="text" name="notes" placeholder="e.g. DFW Apr 25 storm"
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
            </div>

            <!-- Row 2: Map center picker -->
            <div class="flex flex-col gap-2">
                <label class="text-xs text-slate-400">
                    <i class="fa-solid fa-location-crosshairs mr-1 text-brand"></i>
                    Storm Center — search an address or click the map to pin it
                </label>

                <!-- Address search -->
                <div class="flex gap-2">
                    <input type="text" id="centerSearch" placeholder="Search city, neighborhood, or address…"
                           class="flex-1 bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white placeholder-slate-500 focus:border-brand focus:outline-none" />
                    <button type="button" onclick="geocodeSearch()"
                            class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium transition-colors">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>

                <!-- Map -->
                <div id="centerMap" class="w-full rounded-xl border border-slate-600 overflow-hidden" style="height:260px"></div>

                <!-- Coordinate readout + hidden form fields -->
                <div class="flex items-center gap-3 text-xs text-slate-500">
                    <i class="fa-solid fa-crosshairs text-brand"></i>
                    <span id="coordDisplay">No location selected — search above or click the map</span>
                    <input type="hidden" id="centerLat" name="centerLat" value="0" />
                    <input type="hidden" id="centerLng" name="centerLng" value="0" />
                </div>
            </div>

            <!-- Submit -->
            <div class="flex justify-end">
                <button type="submit" id="createBtn" disabled
                        class="px-6 py-2 rounded-lg bg-brand text-white text-sm font-semibold transition-colors opacity-40 cursor-not-allowed"
                        title="Pin a location on the map first">
                    <i class="fa-solid fa-plus mr-1"></i>Create Campaign
                </button>
            </div>
        </form>
    </section>

    <!-- Campaigns table -->
    <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-bullhorn mr-1.5 text-slate-400"></i>Campaigns
        </h2>
        @if (!campaigns.Any()) {
        <p class="text-slate-500 text-sm">No campaigns yet. Create one above.</p>
        } else {
        <div class="overflow-x-auto rounded-xl border border-slate-700/60">
            <table class="w-full text-sm">
                <thead class="bg-slate-800/80 text-xs text-slate-400 uppercase tracking-wider">
                    <tr>
                        <th class="px-4 py-3 text-left">ID</th>
                        <th class="px-4 py-3 text-left">State</th>
                        <th class="px-4 py-3 text-left">Storm Date</th>
                        <th class="px-4 py-3 text-left">Hail</th>
                        <th class="px-4 py-3 text-left">Radius</th>
                        <th class="px-4 py-3 text-left">Status</th>
                        <th class="px-4 py-3 text-right">Sent</th>
                        <th class="px-4 py-3 text-right">Responded</th>
                        <th class="px-4 py-3 text-left">Notes</th>
                        <th class="px-4 py-3 text-left">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700/40">
                @foreach (var c in campaigns) {
                    <tr class="hover:bg-slate-800/40 transition-colors">
                        <td class="px-4 py-3 text-slate-400 font-mono text-xs">#@c.Id</td>
                        <td class="px-4 py-3 font-semibold">@c.StateAbbr</td>
                        <td class="px-4 py-3 text-slate-300">@c.StormDate.ToString("MMM d, yyyy")</td>
                        <td class="px-4 py-3 text-slate-300">@c.HailSizeInches.ToString("0.00")"</td>
                        <td class="px-4 py-3 text-slate-400">@c.RadiusMiles mi</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs font-semibold border @StatusBadge(c.Status)">
                                @c.Status
                            </span>
                        </td>
                        <td class="px-4 py-3 text-right text-slate-300">@c.TotalSent</td>
                        <td class="px-4 py-3 text-right text-brand font-semibold">@c.TotalResponded</td>
                        <td class="px-4 py-3 text-slate-500 text-xs max-w-xs truncate">@c.Notes</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                @if (c.Status == "draft") {
                                <form method="post" action="/LeadGen/FireBlast" class="inline"
                                      onsubmit="return confirm('Fire SMS blast for campaign #@c.Id?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="campaignId" value="@c.Id" />
                                    <button type="submit"
                                            class="px-3 py-1 rounded-lg bg-brand/10 border border-brand/30 text-brand text-xs font-semibold hover:bg-brand/20 transition-colors">
                                        <i class="fa-solid fa-paper-plane mr-1"></i>Fire Blast
                                    </button>
                                </form>
                                } else {
                                <span class="text-xs text-slate-600">@(c.SentAt?.ToString("MMM d HH:mm") ?? "—")</span>
                                }
                                <button onclick="openEditModal(@c.Id,'@c.StateAbbr','@c.StormDate.ToString("yyyy-MM-dd")',@c.HailSizeInches.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture),@c.CenterLat.ToString("0.000000", System.Globalization.CultureInfo.InvariantCulture),@c.CenterLng.ToString("0.000000", System.Globalization.CultureInfo.InvariantCulture),@c.RadiusMiles.ToString("0", System.Globalization.CultureInfo.InvariantCulture),'@Html.Raw(c.Notes.Replace("'", "\\'"))','@c.Status')"
                                        class="px-2 py-1 rounded text-xs text-slate-300 border border-slate-600 bg-slate-700/50 hover:bg-slate-600 transition-colors">
                                    <i class="fa-solid fa-pencil"></i>
                                </button>
                                <form method="post" action="/LeadGen/ResetCampaign" class="inline"
                                      onsubmit="return confirm('Reset campaign #@c.Id to draft and clear contact history?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="campaignId" value="@c.Id" />
                                    <button type="submit"
                                            class="px-2 py-1 rounded text-xs text-yellow-400 border border-yellow-500/20 bg-yellow-500/5 hover:bg-yellow-500/15 transition-colors"
                                            title="Reset to draft / clear contact history">
                                        <i class="fa-solid fa-rotate-left"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        }
    </section>

    <!-- Targets (blast recipients) -->
    <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-mobile-screen-button mr-1.5 text-slate-400"></i>Blast Targets
            <span class="ml-2 text-slate-500 normal-case font-normal">phone numbers queued per campaign</span>
        </h2>

        <!-- Add target form -->
        @{
            var draftCampaigns = campaigns.Where(c => c.Status == "draft").ToList();
        }
        @if (draftCampaigns.Any()) {
        <form method="post" action="/LeadGen/AddTarget"
              class="bg-slate-800/60 border border-slate-700/60 rounded-xl p-4 mb-4 flex flex-wrap gap-3 items-end">
            @Html.AntiForgeryToken()
            <div class="flex flex-col gap-1">
                <label class="text-xs text-slate-400">Campaign</label>
                <select name="campaignId" class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none">
                    @foreach (var c in draftCampaigns) {
                        <option value="@c.Id">#@c.Id — @c.StateAbbr @c.StormDate.ToString("MMM d")</option>
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-xs text-slate-400">Phone</label>
                <input type="tel" name="phone" required placeholder="+19995551234"
                       class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white w-44 focus:border-brand focus:outline-none" />
            </div>
            <div class="flex flex-col gap-1 flex-1">
                <label class="text-xs text-slate-400">Address (optional)</label>
                <input type="text" name="address" placeholder="123 Main St, Dallas TX"
                       class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
            </div>
            <button type="submit"
                    class="px-5 py-2 rounded-lg bg-brand text-white text-sm font-semibold hover:bg-brand-dark transition-colors">
                <i class="fa-solid fa-plus mr-1"></i>Add
            </button>
        </form>
        } else {
        <p class="text-slate-500 text-sm mb-4">Create a draft campaign first, then add targets to it.</p>
        }

        @if (!targets.Any()) {
        <p class="text-slate-600 text-sm">No targets yet.</p>
        } else {
        <div class="overflow-x-auto rounded-xl border border-slate-700/60">
            <table class="w-full text-sm">
                <thead class="bg-slate-800/80 text-xs text-slate-400 uppercase tracking-wider">
                    <tr>
                        <th class="px-4 py-3 text-left">Campaign</th>
                        <th class="px-4 py-3 text-left">Phone</th>
                        <th class="px-4 py-3 text-left">Address</th>
                        <th class="px-4 py-3 text-left">Added</th>
                        <th class="px-4 py-3 text-left"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700/40">
                @foreach (var t in targets) {
                    <tr class="hover:bg-slate-800/40 transition-colors" id="target-@t.Id">
                        <td class="px-4 py-3 text-slate-500 font-mono text-xs">#@t.CampaignId</td>
                        <td class="px-4 py-3 font-mono text-xs text-slate-300">@t.Phone</td>
                        <td class="px-4 py-3 text-slate-400 text-xs">@(string.IsNullOrEmpty(t.Address) ? "—" : t.Address)</td>
                        <td class="px-4 py-3 text-slate-500 text-xs whitespace-nowrap">@t.AddedAt.ToString("MMM d HH:mm")</td>
                        <td class="px-4 py-3">
                            <button onclick="removeTarget(@t.Id)"
                                    class="px-2 py-1 rounded text-xs text-red-400 border border-red-500/20 bg-red-500/5 hover:bg-red-500/15 transition-colors"
                                    title="Remove target">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        }
    </section>

    <!-- Leads table -->
    <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-fire mr-1.5 text-brand"></i>Warm Leads
            <span class="ml-2 text-slate-500 normal-case font-normal">most recent 200</span>
        </h2>
        @if (!leads.Any()) {
        <div class="bg-slate-800/40 border border-slate-700/60 rounded-xl p-8 text-center text-slate-500 text-sm">
            <i class="fa-solid fa-inbox text-3xl text-slate-700 mb-3 block"></i>
            No leads yet. Leads appear here when homeowners reply to a blast SMS.
        </div>
        } else {
        <div class="overflow-x-auto rounded-xl border border-slate-700/60">
            <table class="w-full text-sm">
                <thead class="bg-slate-800/80 text-xs text-slate-400 uppercase tracking-wider">
                    <tr>
                        <th class="px-4 py-3 text-left">Campaign</th>
                        <th class="px-4 py-3 text-left">Responded</th>
                        <th class="px-4 py-3 text-left">Phone</th>
                        <th class="px-4 py-3 text-left">Name</th>
                        <th class="px-4 py-3 text-left">Address</th>
                        <th class="px-4 py-3 text-left">Hail</th>
                        <th class="px-4 py-3 text-left">Response</th>
                        <th class="px-4 py-3 text-left">Status</th>
                        <th class="px-4 py-3 text-left">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-700/40">
                @foreach (var l in leads) {
                    <tr class="hover:bg-slate-800/40 transition-colors" id="lead-@l.Id">
                        <td class="px-4 py-3 text-slate-500 font-mono text-xs">#@l.CampaignId</td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap">@l.RespondedAt.ToString("MMM d HH:mm")</td>
                        <td class="px-4 py-3 font-mono text-xs text-slate-300">@l.HomeownerPhone</td>
                        <td class="px-4 py-3 text-slate-300">@(string.IsNullOrEmpty(l.HomeownerName) ? "—" : l.HomeownerName)</td>
                        <td class="px-4 py-3 text-slate-300 max-w-xs truncate">@(string.IsNullOrEmpty(l.Address) ? "—" : l.Address)</td>
                        <td class="px-4 py-3 text-slate-300 whitespace-nowrap">@l.HailSizeInches.ToString("0.00")"</td>
                        <td class="px-4 py-3 text-slate-300 max-w-xs">
                            <span class="italic text-slate-400">"@l.ResponseText"</span>
                        </td>
                        <td class="px-4 py-3">
                            <select onchange="updateStatus(@l.Id, this.value)"
                                    class="bg-slate-900 border border-slate-600 rounded-lg px-2 py-1 text-xs text-white focus:border-brand focus:outline-none">
                                <option value="new"       selected="@(l.Status=="new"       ? "selected" : null)">New</option>
                                <option value="available" selected="@(l.Status=="available" ? "selected" : null)">Available</option>
                                <option value="sold"      selected="@(l.Status=="sold"      ? "selected" : null)">Sold</option>
                                <option value="expired"   selected="@(l.Status=="expired"   ? "selected" : null)">Expired</option>
                            </select>
                        </td>
                        <td class="px-4 py-3">
                            <button onclick="suppressPhone('@l.HomeownerPhone', @l.Id)"
                                    class="px-2 py-1 rounded text-xs text-red-400 border border-red-500/20 bg-red-500/5 hover:bg-red-500/15 transition-colors"
                                    title="Suppress this number">
                                <i class="fa-solid fa-ban"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        }
    </section>

</main>

<script>
// ── Campaign center map picker ────────────────────────────────────────────
(function () {
    var map    = L.map('centerMap', { zoomControl: true }).setView([32.8, -97.3], 7); // default: DFW
    var marker = null;

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '© OpenStreetMap © CARTO', maxZoom: 19
    }).addTo(map);

    function setPin(lat, lng) {
        lat = Math.round(lat * 1e6) / 1e6;
        lng = Math.round(lng * 1e6) / 1e6;

        if (marker) {
            marker.setLatLng([lat, lng]);
        } else {
            marker = L.marker([lat, lng], { draggable: true }).addTo(map);
            marker.on('dragend', function () {
                var p = marker.getLatLng();
                setPin(p.lat, p.lng);
            });
        }

        document.getElementById('centerLat').value = lat;
        document.getElementById('centerLng').value = lng;
        document.getElementById('coordDisplay').textContent =
            lat.toFixed(5) + ', ' + lng.toFixed(5) + '  (drag pin to adjust)';

        var btn = document.getElementById('createBtn');
        btn.disabled = false;
        btn.classList.remove('opacity-40', 'cursor-not-allowed');
        btn.removeAttribute('title');
    }

    // Click map to place/move pin
    map.on('click', function (e) {
        setPin(e.latlng.lat, e.latlng.lng);
        map.panTo(e.latlng);
    });

    // Address search via Google Geocoding API
    window.geocodeSearch = function () {
        var q = document.getElementById('centerSearch').value.trim();
        if (!q) return;
        var key = '@ViewBag.GoogleMapsApiKey';
        var url = 'https://maps.googleapis.com/maps/api/geocode/json?address='
                  + encodeURIComponent(q) + '&key=' + key;

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.status === 'OK' && data.results.length > 0) {
                    var loc = data.results[0].geometry.location;
                    setPin(loc.lat, loc.lng);
                    map.setView([loc.lat, loc.lng], 11);
                } else {
                    alert('Address not found. Try a different search.');
                }
            })
            .catch(function () { alert('Geocode request failed. Check your network.'); });
    };

    // Allow pressing Enter in search box
    document.getElementById('centerSearch').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); window.geocodeSearch(); }
    });

    // Validate lat/lng are set before form submit
    document.getElementById('campaignForm').addEventListener('submit', function (e) {
        var lat = parseFloat(document.getElementById('centerLat').value);
        var lng = parseFloat(document.getElementById('centerLng').value);
        if (lat === 0 && lng === 0) {
            e.preventDefault();
            alert('Please pin a storm center location on the map before creating the campaign.');
        }
    });
})();

function updateStatus(leadId, status) {
    fetch('/LeadGen/UpdateLeadStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'leadId=' + leadId + '&status=' + encodeURIComponent(status)
    }).catch(function(e) { console.warn('Status update failed', e); });
}

function removeTarget(targetId) {
    if (!confirm('Remove this target?')) return;
    fetch('/LeadGen/RemoveTarget', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'targetId=' + targetId
    }).then(function() {
        var row = document.getElementById('target-' + targetId);
        if (row) row.remove();
    }).catch(function(e) { console.warn('Remove target failed', e); });
}

function suppressPhone(phone, leadId) {
    if (!confirm('Permanently suppress ' + phone + '? They will never be texted again.')) return;
    fetch('/LeadGen/Suppress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'phone=' + encodeURIComponent(phone)
    }).then(function() {
        var row = document.getElementById('lead-' + leadId);
        if (row) row.style.opacity = '0.35';
    }).catch(function(e) { console.warn('Suppress failed', e); });
}
</script>

<!-- Edit Campaign Modal -->
<div id="editModal" class="fixed inset-0 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4" style="z-index:2000">
    <div class="bg-[#1e293b] border border-slate-700 rounded-2xl w-full max-w-2xl shadow-2xl">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-700">
            <h3 class="font-bold text-white">Edit Campaign <span id="editModalId" class="text-brand"></span></h3>
            <button onclick="closeEditModal()" class="text-slate-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
        <form method="post" action="/LeadGen/UpdateCampaign" class="p-6 space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editCampaignId" name="campaignId" />

            <!-- Fields (disabled for non-draft) -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="editDraftFields">
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">State</label>
                    <select id="editState" name="stateAbbr" class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none">
                        <option value="TX">TX</option>
                        <option value="OK">OK</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Storm Date</label>
                    <input type="date" id="editStormDate" name="stormDate"
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Hail Size (in)</label>
                    <input type="number" id="editHailSize" name="hailSizeInches" step="0.25" min="0.75" max="5"
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-slate-400">Radius (mi)</label>
                    <input type="number" id="editRadius" name="radiusMiles" step="1" min="1" max="100"
                           class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
                </div>
            </div>

            <!-- Map picker (draft only) -->
            <div id="editMapSection" class="flex flex-col gap-2">
                <label class="text-xs text-slate-400">
                    <i class="fa-solid fa-location-crosshairs mr-1 text-brand"></i>Storm Center — click map or drag pin to adjust
                </label>
                <div id="editMap" class="w-full rounded-xl border border-slate-600 overflow-hidden" style="height:220px"></div>
                <div class="text-xs text-slate-500 flex items-center gap-2">
                    <i class="fa-solid fa-crosshairs text-brand"></i>
                    <span id="editCoordDisplay"></span>
                </div>
                <input type="hidden" id="editCenterLat" name="centerLat" />
                <input type="hidden" id="editCenterLng" name="centerLng" />
            </div>

            <!-- Notes (always editable) -->
            <div class="flex flex-col gap-1">
                <label class="text-xs text-slate-400">Notes</label>
                <input type="text" id="editNotes" name="notes" placeholder="e.g. DFW Apr 25 storm"
                       class="bg-slate-900 border border-slate-600 rounded-lg px-3 py-2 text-sm text-white focus:border-brand focus:outline-none" />
            </div>

            <div id="editReadonlyNote" class="hidden text-xs text-slate-500 italic">
                <i class="fa-solid fa-lock mr-1"></i>State, date, hail size, radius and location are locked after a blast has fired. Only notes can be changed.
            </div>

            <div class="flex justify-end gap-3 pt-2">
                <button type="button" onclick="closeEditModal()"
                        class="px-4 py-2 rounded-lg border border-slate-600 text-slate-300 text-sm hover:bg-slate-700 transition-colors">Cancel</button>
                <button type="submit"
                        class="px-5 py-2 rounded-lg bg-brand hover:bg-brand-dark text-white text-sm font-semibold transition-colors">
                    <i class="fa-solid fa-floppy-disk mr-1"></i>Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
var editMap = null, editMarker = null;

function openEditModal(id, state, stormDate, hailSize, lat, lng, radius, notes, status) {
    document.getElementById('editCampaignId').value  = id;
    document.getElementById('editModalId').textContent = '#' + id;
    document.getElementById('editState').value       = state;
    document.getElementById('editStormDate').value   = stormDate;
    document.getElementById('editHailSize').value    = hailSize;
    document.getElementById('editRadius').value      = radius;
    document.getElementById('editNotes').value       = notes;
    document.getElementById('editCenterLat').value   = lat;
    document.getElementById('editCenterLng').value   = lng;
    document.getElementById('editCoordDisplay').textContent = lat + ', ' + lng + '  (drag pin to adjust)';

    var isDraft = status === 'draft';
    // Lock non-notes fields for non-draft campaigns
    ['editState','editStormDate','editHailSize','editRadius'].forEach(function(id) {
        document.getElementById(id).disabled = !isDraft;
    });
    document.getElementById('editMapSection').style.display   = isDraft ? '' : 'none';
    document.getElementById('editReadonlyNote').classList.toggle('hidden', isDraft);

    document.getElementById('editModal').classList.remove('hidden');
    document.getElementById('editModal').classList.add('flex');

    // Init or reset the edit map
    setTimeout(function () {
        if (!editMap) {
            editMap = L.map('editMap', { zoomControl: true }).setView([lat, lng], 10);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '© OpenStreetMap © CARTO', maxZoom: 19
            }).addTo(editMap);
            editMap.on('click', function (e) { setEditPin(e.latlng.lat, e.latlng.lng); });
        } else {
            editMap.setView([lat, lng], 10);
        }

        if (editMarker) {
            editMarker.setLatLng([lat, lng]);
        } else {
            editMarker = L.marker([lat, lng], { draggable: true }).addTo(editMap);
            editMarker.on('dragend', function () {
                var p = editMarker.getLatLng();
                setEditPin(p.lat, p.lng);
            });
        }
        editMap.invalidateSize();
    }, 50);
}

function setEditPin(lat, lng) {
    lat = Math.round(lat * 1e6) / 1e6;
    lng = Math.round(lng * 1e6) / 1e6;
    if (editMarker) editMarker.setLatLng([lat, lng]);
    document.getElementById('editCenterLat').value = lat;
    document.getElementById('editCenterLng').value = lng;
    document.getElementById('editCoordDisplay').textContent = lat + ', ' + lng + '  (drag pin to adjust)';
}

function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
    document.getElementById('editModal').classList.remove('flex');
}

// Close on backdrop click
document.getElementById('editModal').addEventListener('click', function (e) {
    if (e.target === this) closeEditModal();
});
</script>

</body>
</html>
