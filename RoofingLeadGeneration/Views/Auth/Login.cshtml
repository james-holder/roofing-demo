@{
    Layout = null;
    var returnUrl        = ViewData["ReturnUrl"]        as string ?? "/";
    var googleEnabled    = ViewData["GoogleEnabled"]    is true;
    var microsoftEnabled = ViewData["MicrosoftEnabled"] is true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body { background: #0f172a; font-family: ui-sans-serif, system-ui, sans-serif; }
        .btn-provider {
            display: flex; align-items: center; gap: 12px;
            width: 100%; padding: 12px 20px; border-radius: 12px;
            font-size: 14px; font-weight: 600; cursor: pointer;
            transition: background 0.15s, box-shadow 0.15s;
            border: 1.5px solid rgba(255,255,255,0.1);
            background: #1e293b; color: #e2e8f0;
        }
        .btn-provider:hover { background: #263548; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
        .btn-provider img { width: 20px; height: 20px; flex-shrink: 0; }
        .divider { display: flex; align-items: center; gap: 12px; color: #475569; font-size: 12px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #334155; }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

<div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2.5 mb-4">
            <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center shadow-lg">
                <i class="fa-solid fa-house-chimney text-white"></i>
            </div>
            <span class="text-2xl font-extrabold text-white tracking-tight">
                Storm<span class="text-orange-500">Lead</span> Pro
            </span>
        </div>
        <p class="text-slate-400 text-sm">Sign in to access your leads dashboard</p>
    </div>

    <!-- Card -->
    <div class="bg-slate-800/80 border border-slate-700/60 rounded-2xl p-8 shadow-2xl">

        <h2 class="text-white font-bold text-lg mb-6 text-center">Welcome back</h2>

        <div class="space-y-3">

            @if (googleEnabled)
            {
                <a href="/Auth/SignIn/Google?returnUrl=@Uri.EscapeDataString(returnUrl)"
                   class="btn-provider">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Continue with Google
                </a>
            }

            @if (microsoftEnabled)
            {
                <a href="/Auth/SignIn/Microsoft?returnUrl=@Uri.EscapeDataString(returnUrl)"
                   class="btn-provider">
                    <svg viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px">
                        <rect x="1"  y="1"  width="10" height="10" fill="#F25022"/>
                        <rect x="12" y="1"  width="10" height="10" fill="#7FBA00"/>
                        <rect x="1"  y="12" width="10" height="10" fill="#00A4EF"/>
                        <rect x="12" y="12" width="10" height="10" fill="#FFB900"/>
                    </svg>
                    Continue with Microsoft
                </a>
            }

            @if (!googleEnabled && !microsoftEnabled)
            {
                <div class="text-center text-slate-400 text-sm py-4">
                    <i class="fa-solid fa-triangle-exclamation text-orange-400 mr-2"></i>
                    No auth providers configured yet.<br />
                    Add your Google or Microsoft credentials to <code class="text-orange-400">appsettings.json</code>.
                </div>
            }

        </div>

        @if (System.Diagnostics.Debugger.IsAttached ||
             string.Equals(Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT"), "Development", StringComparison.OrdinalIgnoreCase))
        {
            <div class="mt-6">
                <div class="divider">dev only</div>
                <a href="/Auth/DevLogin?returnUrl=@Uri.EscapeDataString(returnUrl)"
                   class="btn-provider mt-3 border-dashed border-slate-600 text-slate-400 hover:text-slate-200">
                    <i class="fa-solid fa-code text-orange-500" style="width:20px;text-align:center"></i>
                    Skip login (Dev Backdoor)
                </a>
            </div>
        }

    </div>

    <p class="text-center text-slate-600 text-xs mt-6">
        StormLead Pro &copy; 2026 &mdash; Your data is private and secure
    </p>

</div>
</body>
</html>
