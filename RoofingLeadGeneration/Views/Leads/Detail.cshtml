@model RoofingLeadGeneration.Data.Models.Lead
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = null;
    var riskColor  = Model.RiskLevel == "High" ? "badge-high" : Model.RiskLevel == "Medium" ? "badge-medium" : "badge-low";
    var roofAge    = (Model.YearBuilt.HasValue) ? (DateTime.Now.Year - Model.YearBuilt.Value) : (int?)null;
    var roofAgeColor = roofAge == null ? "text-slate-500" :
                       roofAge < 8    ? "text-green-400" :
                       roofAge < 15   ? "text-yellow-400" :
                       roofAge < 20   ? "text-orange-400" : "text-red-400";
    var roofAgePct   = roofAge == null ? 0 : Math.Min(100, (int)(roofAge.Value / 25.0 * 100));
    var roofAgeFill  = roofAge == null ? "bg-slate-600" :
                       roofAge < 8    ? "bg-green-400" :
                       roofAge < 15   ? "bg-yellow-400" :
                       roofAge < 20   ? "bg-orange-400" : "bg-red-500";
    var statusLabels = new Dictionary<string,string> {
        {"new","New"}, {"contacted","Contacted"}, {"appointment_set","Appt Set"},
        {"closed_won","Won ✓"}, {"closed_lost","Lost"}
    };
    var currentStatusLabel = statusLabels.ContainsKey(Model.Status) ? statusLabels[Model.Status] : "New";
    var statusCssMap = new Dictionary<string,string> {
        {"new","new"}, {"contacted","contacted"}, {"appointment_set","appt"},
        {"closed_won","won"}, {"closed_lost","lost"}
    };
    var statusCssClass = "status-" + (statusCssMap.ContainsKey(Model.Status) ? statusCssMap[Model.Status] : "new");
    var canEnrich = (bool)(ViewBag.CanEnrich ?? false);
    var primaryContact = Model.Contacts.FirstOrDefault(c => c.IsPrimary) ?? Model.Contacts.FirstOrDefault();
    var hailSizeNum = 0.0;
    double.TryParse(System.Text.RegularExpressions.Regex.Match(Model.HailSize ?? "", @"[\d.]+").Value, out hailSizeNum);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Address — StormLead Pro</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy:  { DEFAULT: '#0f172a', 700: '#1e293b', 600: '#334155', 500: '#475569' },
                        brand: { DEFAULT: '#f97316', dark: '#ea6c0a', light: '#fdba74' }
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <link rel="stylesheet" href="~/css/saved-leads.css" />
    <link rel="stylesheet" href="~/css/lead-detail.css" />
</head>
<body class="min-h-screen bg-[#0b1120]">

<!-- Toast -->
<div id="toast">
    <i id="toastIcon" class="fa-solid fa-circle-check"></i>
    <span id="toastMsg"></span>
</div>

<!-- ══════════════════════════════════════════════════════════════
     HEADER
══════════════════════════════════════════════════════════════ -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">

        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-bold tracking-tight">
                Storm<span class="text-brand">Lead</span> Pro
            </span>
        </a>

        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">
                <i class="fa-solid fa-magnifying-glass mr-1 text-xs"></i>Search
            </a>
            <a href="/Leads/Saved" class="text-white font-semibold">
                <i class="fa-solid fa-bookmark mr-1 text-brand text-xs"></i>Saved Leads
            </a>
            <a href="/Dashboard" class="hover:text-white transition-colors">Dashboard</a>
            <a href="/Alerts" class="hover:text-white transition-colors">
                <i class="fa-solid fa-bell mr-1 text-xs"></i>Alerts
            </a>
            <a href="/Team" class="hover:text-white transition-colors">
                <i class="fa-solid fa-users mr-1 text-xs"></i>Team
            </a>
            <a href="/Help" class="hover:text-white transition-colors">
                <i class="fa-solid fa-circle-question mr-1 text-xs"></i>Help
            </a>
            @if ((User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "") == Configuration["AdminEmail"]) {
                <a href="/Admin" class="text-orange-400 hover:text-orange-300 transition-colors text-xs">
                    <i class="fa-solid fa-shield-halved mr-1"></i>Admin
                </a>
            }
            <span class="text-slate-600">|</span>
            @if (User.Identity?.IsAuthenticated == true) {
                <span class="text-slate-300 text-xs">
                    <i class="fa-solid fa-circle-user mr-1 text-brand"></i>@User.Identity.Name
                </span>
                <a href="/Auth/Logout" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Sign out</a>
            }
        </nav>

        <button id="mobileMenuBtn" onclick="toggleMobileMenu()"
            class="lg:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-700/60 transition-colors">
            <i id="mobileMenuIcon" class="fa-solid fa-bars text-lg"></i>
        </button>
    </div>

    <!-- Mobile nav drawer -->
    <div id="mobileMenu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-[#0f172a] border-t border-slate-700/60 shadow-2xl z-50 px-4 py-3 flex flex-col gap-1">
        <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-magnifying-glass w-4 text-center text-xs"></i>Search
        </a>
        <a href="/Leads/Saved" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-slate-700/60 text-white font-semibold text-sm">
            <i class="fa-solid fa-bookmark text-brand w-4 text-center text-xs"></i>Saved Leads
        </a>
        <a href="/Dashboard" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-chart-bar w-4 text-center text-xs"></i>Dashboard
        </a>
        <a href="/Alerts" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-bell w-4 text-center text-xs"></i>Alerts
        </a>
        <div class="border-t border-slate-700/60 my-1"></div>
        @if (User.Identity?.IsAuthenticated == true) {
            <div class="flex items-center justify-between px-3 py-2">
                <span class="text-slate-300 text-sm"><i class="fa-solid fa-circle-user mr-2 text-brand"></i>@User.Identity.Name</span>
                <a href="/Auth/Logout" class="text-xs text-slate-500 hover:text-slate-300 transition-colors px-3 py-1.5 rounded-lg hover:bg-slate-700/60">Sign out</a>
            </div>
        }
    </div>
</header>

<!-- ══════════════════════════════════════════════════════════════
     HERO / LEAD HEADER
══════════════════════════════════════════════════════════════ -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-5">

        <!-- Back breadcrumb -->
        <a href="/Leads/Saved" class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-slate-300 transition-colors mb-3 group">
            <i class="fa-solid fa-arrow-left text-xs group-hover:-translate-x-0.5 transition-transform"></i>
            Saved Leads
        </a>

        <div class="flex flex-wrap items-start justify-between gap-4">
            <!-- Address + badges -->
            <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="@riskColor px-2.5 py-0.5 rounded-full text-xs font-bold">@(Model.RiskLevel ?? "Unknown")</span>
                    @if (!string.IsNullOrEmpty(Model.HailSize) && Model.HailSize != "No data") {
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-700 border border-slate-600 text-slate-300">
                            <i class="fa-solid fa-cloud-bolt mr-1 text-brand text-xs"></i>@Model.HailSize
                        </span>
                    }
                    @if (Model.IsEnriched) {
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-500/15 border border-green-500/30 text-green-400">
                            <i class="fa-solid fa-circle-check mr-1 text-xs"></i>Enriched
                        </span>
                    }
                </div>
                <h1 class="text-xl sm:text-2xl font-extrabold text-white leading-tight">@Model.Address</h1>
                @if (!string.IsNullOrEmpty(Model.SourceAddress)) {
                    <p class="text-xs text-slate-500 mt-0.5">
                        <i class="fa-solid fa-location-dot mr-1"></i>from scan: @Model.SourceAddress
                    </p>
                }
            </div>

            <!-- Action buttons -->
            <div class="flex flex-wrap items-center gap-2 flex-shrink-0">
                @if (canEnrich && !Model.IsEnriched) {
                    <button id="enrichBtn" onclick="detailEnrich(@Model.Id)"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-brand hover:bg-brand-dark text-white text-xs font-semibold transition shadow">
                        <i class="fa-solid fa-bolt"></i>Enrich Lead
                    </button>
                }
                <a href="/Leads/@Model.Id/Report" target="_blank"
                    class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-sky-500/10 hover:bg-sky-500/25 border border-sky-500/25 text-sky-400 text-xs font-semibold transition">
                    <i class="fa-solid fa-file-pdf"></i>PDF Report
                </a>
            </div>
        </div>

        <!-- Status + Pipeline quick row -->
        <div class="flex flex-wrap items-center gap-3 mt-4">
            <span class="text-xs text-slate-500 font-semibold uppercase tracking-wide">Pipeline</span>
            <select id="statusBadge" onchange="detailSetStatus(@Model.Id, this.value)"
                class="status-select @statusCssClass">
                <option value="new"             selected="@(Model.Status=="new"             ? "selected" : null)">New</option>
                <option value="contacted"       selected="@(Model.Status=="contacted"       ? "selected" : null)">Contacted</option>
                <option value="appointment_set" selected="@(Model.Status=="appointment_set" ? "selected" : null)">Appt Set</option>
                <option value="closed_won"      selected="@(Model.Status=="closed_won"      ? "selected" : null)">Won</option>
                <option value="closed_lost"     selected="@(Model.Status=="closed_lost"     ? "selected" : null)">Lost</option>
            </select>
            <span class="text-slate-600 text-xs">·</span>
            <span class="text-xs text-slate-500">Saved @Model.SavedAt.ToString("MMM d, yyyy")</span>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB BAR
══════════════════════════════════════════════════════════════ -->
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-1 overflow-x-auto">
    <div class="inline-flex min-w-full sm:min-w-0 rounded-xl bg-slate-800 border border-slate-700 p-1 gap-1">
        <button id="tab_overview" class="detail-tab" onclick="showTab('overview')" tabindex="0">
            <i class="fa-solid fa-house-chimney text-xs"></i>
            Overview
        </button>
        <button id="tab_property" class="detail-tab" onclick="showTab('property')" tabindex="0">
            <i class="fa-solid fa-ruler-combined text-xs"></i>
            Property
        </button>
        <button id="tab_contacts" class="detail-tab" onclick="showTab('contacts')" tabindex="0">
            <i class="fa-solid fa-users text-xs"></i>
            Contacts
            @if (Model.Contacts.Count > 0) {
                <span class="px-1.5 py-0.5 rounded-full bg-slate-700/80 text-xs font-bold text-slate-300">@Model.Contacts.Count</span>
            }
        </button>
        <button id="tab_activity" class="detail-tab" onclick="showTab('activity')" tabindex="0">
            <i class="fa-solid fa-timeline text-xs"></i>
            Activity
            @if (!string.IsNullOrEmpty(Model.Notes)) {
                <span id="notesDot" class="inline-block w-1.5 h-1.5 rounded-full bg-amber-400"></span>
            } else {
                <span id="notesDot" class="hidden inline-block w-1.5 h-1.5 rounded-full bg-amber-400"></span>
            }
        </button>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: OVERVIEW
══════════════════════════════════════════════════════════════ -->
<div id="panel_overview" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

        <!-- LEFT: Claim countdown + Storm events -->
        <div class="lg:col-span-2 space-y-5">

            <!-- Claim countdown card -->
            <div id="claimCountdownCard"
                 data-storm-date="@(Model.LastStormDate ?? "")"
                 data-address="@Model.Address"
                 class="claim-card">
                <p class="text-slate-500 text-sm">Calculating claim window…</p>
            </div>

            <!-- Storm event(s) -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest">
                        <i class="fa-solid fa-cloud-bolt mr-1.5 text-brand"></i>Storm Events
                    </h3>
                    <a href="/?address=@Uri.EscapeDataString(Model.Address)"
                       class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
                        <i class="fa-solid fa-magnifying-glass mr-1"></i>Run new scan
                    </a>
                </div>

                @if (!string.IsNullOrEmpty(Model.LastStormDate) && Model.LastStormDate != "No data") {
                    <div class="storm-row storm-primary">
                        <div class="storm-dot storm-dot-primary"></div>
                        <div class="flex-1">
                            <span class="text-white font-semibold text-sm">@Model.LastStormDate</span>
                            @if (!string.IsNullOrEmpty(Model.HailSize) && Model.HailSize != "No data") {
                                <span class="text-slate-400 text-xs ml-2">@Model.HailSize</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.HailSize)) {
                            <span class="px-2 py-0.5 rounded-full text-xs font-bold @riskColor">@(Model.RiskLevel ?? "—")</span>
                        }
                        <span class="text-xs text-slate-500 flex-shrink-0">most recent</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-2 pl-1">
                        <i class="fa-solid fa-circle-info mr-1"></i>Showing data from last scan · run a new scan for full history
                    </p>
                } else {
                    <div class="storm-row">
                        <div class="storm-dot storm-dot-secondary"></div>
                        <p class="text-slate-500 text-sm">No storm events recorded — run a new scan to check.</p>
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT: Owner quick-contact -->
        <div class="space-y-4">
            <div class="rounded-xl bg-slate-800/50 border border-slate-700/60 p-4">
                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                    <i class="fa-solid fa-user mr-1.5"></i>Owner
                </h3>

                @if (!string.IsNullOrEmpty(Model.OwnerName)) {
                    <p class="text-white font-semibold text-sm mb-3">@Model.OwnerName</p>
                } else {
                    <p class="text-slate-600 italic text-sm mb-3">Name unknown</p>
                }

                <div class="space-y-2">
                    @if (!string.IsNullOrEmpty(Model.OwnerPhone)) {
                        <a href="tel:@Model.OwnerPhone" class="contact-action contact-action-call w-full">
                            <i class="fa-solid fa-phone text-xs"></i>@Model.OwnerPhone
                        </a>
                    } else {
                        <div class="contact-action w-full border-slate-700 text-slate-600 cursor-default">
                            <i class="fa-solid fa-phone-slash text-xs"></i>No phone yet
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.OwnerEmail)) {
                        <a href="mailto:@Model.OwnerEmail" class="contact-action contact-action-email w-full">
                            <i class="fa-solid fa-envelope text-xs"></i>
                            <span class="truncate">@Model.OwnerEmail</span>
                        </a>
                    }
                </div>

                @if (!Model.IsEnriched && canEnrich) {
                    <div class="mt-3 pt-3 border-t border-slate-700/60">
                        <p class="text-xs text-slate-500 mb-2">Contact info not yet enriched.</p>
                        <button onclick="detailEnrich(@Model.Id)"
                            class="w-full flex items-center justify-center gap-1.5 py-2 rounded-xl bg-brand/10 hover:bg-brand/20 border border-brand/25 text-brand text-xs font-semibold transition">
                            <i class="fa-solid fa-bolt text-xs"></i>Enrich for contacts
                        </button>
                    </div>
                }
            </div>

            <!-- Quick notes preview -->
            @if (!string.IsNullOrEmpty(Model.Notes)) {
                <div class="rounded-xl bg-amber-500/5 border border-amber-500/20 p-4">
                    <h3 class="text-xs font-bold text-amber-400 uppercase tracking-widest mb-2">
                        <i class="fa-solid fa-note-sticky mr-1.5"></i>Note
                    </h3>
                    <p class="text-slate-300 text-xs leading-relaxed">
                        @(Model.Notes.Length > 120 ? Model.Notes.Substring(0, 120) + "…" : Model.Notes)
                    </p>
                    <button onclick="showTab('activity')" class="text-xs text-amber-400 hover:text-amber-300 mt-2 transition-colors">
                        Edit note →
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: PROPERTY
══════════════════════════════════════════════════════════════ -->
<div id="panel_property" class="hidden max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

        <!-- Property data card -->
        <div class="rounded-2xl bg-slate-800/50 border border-slate-700/60 p-5">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">
                <i class="fa-solid fa-house-user mr-1.5 text-brand"></i>Property Details
            </h3>

            <!-- Roof age -->
            @if (roofAge.HasValue) {
                <div class="mb-4">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs text-slate-500 font-medium">Estimated Roof Age</span>
                        <span class="text-sm font-bold @roofAgeColor">~@roofAge yrs</span>
                    </div>
                    <div class="roof-age-bar">
                        <div class="roof-age-fill @roofAgeFill" style="width: @(roofAgePct)%"></div>
                    </div>
                    <div class="flex justify-between text-xs text-slate-600 mt-1">
                        <span>0 yrs</span>
                        <span class="@roofAgeColor text-xs font-medium">
                            @(roofAge < 8 ? "Likely new" : roofAge < 15 ? "Mid-life" : roofAge < 20 ? "Getting old" : "Strong candidate")
                        </span>
                        <span>25+ yrs</span>
                    </div>
                </div>
                <div class="border-t border-slate-700/50 mb-4"></div>
            }

            <div>
                <div class="prop-row">
                    <span class="prop-label">Year Built</span>
                    <span class="prop-value">
                        @(Model.YearBuilt.HasValue ? Model.YearBuilt.Value.ToString() : "—")
                    </span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Property Type</span>
                    <span class="prop-value">@(string.IsNullOrEmpty(Model.PropertyType) ? "—" : Model.PropertyType)</span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Roof Material</span>
                    <span class="prop-value text-slate-500 italic text-xs">Needs ATTOM trial</span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Owner-Occupied</span>
                    <span class="prop-value text-slate-500 italic text-xs">Needs ATTOM trial</span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Last Sale</span>
                    <span class="prop-value text-slate-500 italic text-xs">Needs ATTOM trial</span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Scan Source</span>
                    <span class="prop-value text-right">@(string.IsNullOrEmpty(Model.SourceAddress) ? "—" : Model.SourceAddress)</span>
                </div>
                <div class="prop-row">
                    <span class="prop-label">Coordinates</span>
                    <span class="prop-value text-xs text-slate-400">
                        @(Model.Lat.HasValue ? Model.Lat.Value.ToString("F5") : "—"),
                        @(Model.Lng.HasValue ? Model.Lng.Value.ToString("F5") : "—")
                    </span>
                </div>
            </div>

            <div class="mt-4 pt-3 border-t border-slate-700/50">
                <p class="text-xs text-slate-600">
                    <i class="fa-solid fa-circle-info mr-1"></i>
                    Roof material, owner-occupancy, and last sale date unlock when the ATTOM TX pilot ships.
                </p>
            </div>
        </div>

        <!-- Map -->
        <div class="rounded-2xl bg-slate-800/50 border border-slate-700/60 p-5">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                <i class="fa-solid fa-map-location-dot mr-1.5 text-brand"></i>Location
            </h3>
            <div id="propertyMap"
                 data-lat="@(Model.Lat?.ToString() ?? "")"
                 data-lng="@(Model.Lng?.ToString() ?? "")">
            </div>
            @if (Model.Lat.HasValue && Model.Lng.HasValue) {
                <a href="https://www.google.com/maps/search/?api=1&query=@(Uri.EscapeDataString(Model.Address))"
                   target="_blank"
                   class="mt-3 inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-slate-300 transition-colors">
                    <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>Open in Google Maps
                </a>
            }
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: CONTACTS
══════════════════════════════════════════════════════════════ -->
<div id="panel_contacts" class="hidden max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    @if (Model.Contacts.Count > 0) {
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest">
                <i class="fa-solid fa-users mr-1.5 text-brand"></i>@Model.Contacts.Count Contact@(Model.Contacts.Count != 1 ? "s" : "")
            </h3>
            @if (canEnrich) {
                <button id="reEnrichBtn" onclick="detailReEnrich(@Model.Id)"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-700 hover:bg-slate-600 border border-slate-600 text-slate-300 text-xs font-semibold transition">
                    <i class="fa-solid fa-rotate text-xs"></i>Re-enrich
                </button>
            }
        </div>

        @foreach (var contact in Model.Contacts.OrderByDescending(c => c.IsPrimary)) {
            <div class="contact-card @(contact.IsPrimary ? "contact-primary" : "")">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-slate-400">
                            <i class="fa-solid fa-user text-xs"></i>
                        </div>
                        <div>
                            <p class="text-white font-semibold text-sm">@(contact.Name ?? "Unknown")</p>
                            <div class="flex items-center gap-2 mt-0.5">
                                @if (contact.IsPrimary) {
                                    <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold bg-green-500/15 text-green-400 border border-green-500/20">Primary</span>
                                }
                                <span class="px-1.5 py-0.5 rounded-full text-xs font-semibold @(contact.ContactType == "owner" ? "bg-orange-500/15 text-orange-400 border border-orange-500/20" : "bg-slate-700 text-slate-400 border border-slate-600")">
                                    @contact.ContactType
                                </span>
                                <span class="text-xs text-slate-600">via @contact.Source</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex flex-wrap gap-2">
                    @if (!string.IsNullOrEmpty(contact.Phone)) {
                        <a href="tel:@contact.Phone" class="contact-action contact-action-call">
                            <i class="fa-solid fa-phone text-xs"></i>@contact.Phone
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(contact.Email)) {
                        <a href="mailto:@contact.Email" class="contact-action contact-action-email">
                            <i class="fa-solid fa-envelope text-xs"></i>@contact.Email
                        </a>
                    }
                    @if (string.IsNullOrEmpty(contact.Phone) && string.IsNullOrEmpty(contact.Email)) {
                        <span class="text-xs text-slate-600 italic">No contact details</span>
                    }
                </div>
            </div>
        }

        <!-- DNC notice -->
        <div class="mt-4 p-4 rounded-xl bg-slate-800/50 border border-slate-700/60">
            <p class="text-xs text-slate-500">
                <i class="fa-solid fa-shield-halved mr-1.5 text-slate-600"></i>
                DNC scrubbing ships with the SMS outreach feature (Priority 2.5). Until then, always
                verify numbers before texting. See TCPA compliance item on the roadmap.
            </p>
        </div>

    } else if (!Model.IsEnriched) {
        <!-- Not enriched CTA -->
        <div class="flex flex-col items-center justify-center py-16 text-center gap-3">
            <div class="w-14 h-14 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center mb-2">
                <i class="fa-solid fa-user-plus text-2xl text-slate-600"></i>
            </div>
            <p class="text-slate-300 font-semibold">No contacts yet</p>
            <p class="text-slate-500 text-sm max-w-xs">Enrich this lead to pull owner name, phone, and email from Whitepages Pro or BatchSkipTracing.</p>
            @if (canEnrich) {
                <button onclick="detailEnrich(@Model.Id)"
                    class="mt-2 flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand hover:bg-brand-dark text-white text-sm font-semibold transition shadow">
                    <i class="fa-solid fa-bolt"></i>Enrich this lead
                </button>
            } else {
                <p class="text-xs text-slate-600">Contact an owner or manager to run enrichment.</p>
            }
        </div>
    } else {
        <!-- Enriched but no contacts found -->
        <div class="flex flex-col items-center justify-center py-16 text-center gap-3">
            <div class="w-14 h-14 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center mb-2">
                <i class="fa-solid fa-user-slash text-2xl text-slate-600"></i>
            </div>
            <p class="text-slate-300 font-semibold">No contacts found</p>
            <p class="text-slate-500 text-sm max-w-xs">Enrichment ran but returned no phone or email for this address. You can try re-enriching — data coverage improves over time.</p>
            @if (canEnrich) {
                <button id="reEnrichBtn" onclick="detailReEnrich(@Model.Id)"
                    class="mt-2 flex items-center gap-2 px-5 py-2.5 rounded-xl bg-slate-700 hover:bg-slate-600 border border-slate-600 text-slate-200 text-sm font-semibold transition">
                    <i class="fa-solid fa-rotate"></i>Try re-enriching
                </button>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: ACTIVITY
══════════════════════════════════════════════════════════════ -->
<div id="panel_activity" class="hidden max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

        <!-- Notes -->
        <div class="rounded-2xl bg-slate-800/50 border border-slate-700/60 p-5">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest">
                    <i class="fa-solid fa-note-sticky mr-1.5 text-amber-400"></i>Notes
                </h3>
                <button id="notesSaveBtn" onclick="detailSaveNotes(@Model.Id)"
                    class="hidden flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-500/20 hover:bg-green-500/30 border border-green-500/30 text-green-400 text-xs font-semibold transition">
                    <i class="fa-solid fa-check text-xs"></i>Save Note
                </button>
            </div>
            <textarea id="detailNotesArea"
                class="detail-notes-textarea"
                rows="5"
                placeholder="Add notes about this lead — call history, homeowner reactions, follow-up reminders…"
                oninput="detailNotesChanged(@Model.Id)"
                onkeydown="if((event.metaKey||event.ctrlKey)&&event.key==='Enter'){detailSaveNotes(@Model.Id);}"
            >@(Model.Notes ?? "")</textarea>
            <p class="text-xs text-slate-600 mt-2"><kbd class="bg-slate-700 px-1.5 py-0.5 rounded text-slate-400 text-xs">Ctrl+Enter</kbd> to save</p>
        </div>

        <!-- Timeline -->
        <div class="rounded-2xl bg-slate-800/50 border border-slate-700/60 p-5">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">
                <i class="fa-solid fa-timeline mr-1.5 text-brand"></i>History
            </h3>

            <div class="space-y-0">

                <!-- Created event -->
                <div class="timeline-item">
                    <div class="timeline-dot timeline-dot-create">
                        <i class="fa-solid fa-plus"></i>
                    </div>
                    <div>
                        <p class="text-slate-300 text-sm font-semibold">Lead saved</p>
                        <p class="text-slate-500 text-xs mt-0.5">@Model.SavedAt.ToString("MMM d, yyyy 'at' h:mm tt") UTC</p>
                        @if (!string.IsNullOrEmpty(Model.SourceAddress)) {
                            <p class="text-xs text-slate-600 mt-0.5">from scan: @Model.SourceAddress</p>
                        }
                    </div>
                </div>

                <!-- Enrichment events (newest first) -->
                @foreach (var enrich in Model.Enrichments.OrderByDescending(e => e.CreatedAt)) {
                    var isSuccess = enrich.Status == "completed";
                    var dotClass  = isSuccess ? "timeline-dot-enrich" : "timeline-dot-error";
                    var icon2     = isSuccess ? "fa-bolt" : "fa-xmark";
                    <div class="timeline-item">
                        <div class="timeline-dot @dotClass">
                            <i class="fa-solid @icon2"></i>
                        </div>
                        <div>
                            <p class="text-slate-300 text-sm font-semibold">
                                @(isSuccess ? "Enriched" : "Enrichment — no data")
                            </p>
                            <p class="text-slate-500 text-xs mt-0.5">@enrich.CreatedAt.ToString("MMM d, yyyy 'at' h:mm tt") UTC</p>
                            <p class="text-xs text-slate-600 mt-0.5">via @enrich.Provider · @enrich.CreditsUsed credit used</p>
                        </div>
                    </div>
                }

                <!-- Current status (if not new) -->
                @if (Model.Status != "new") {
                    <div class="timeline-item">
                        <div class="timeline-dot timeline-dot-status">
                            <i class="fa-solid fa-flag text-xs"></i>
                        </div>
                        <div>
                            <p class="text-slate-300 text-sm font-semibold">Status: @currentStatusLabel</p>
                            <p class="text-xs text-slate-600 mt-0.5">Full status history tracking ships with Team Accounts (Priority 3)</p>
                        </div>
                    </div>
                }

                <!-- PDF reports generated -->
                <div class="timeline-item">
                    <div class="timeline-dot" style="background:rgba(14,165,233,0.15);color:#38bdf8;border:1.5px solid rgba(14,165,233,0.3)">
                        <i class="fa-solid fa-file-pdf" style="font-size:0.55rem"></i>
                    </div>
                    <div>
                        <p class="text-slate-300 text-sm font-semibold">PDF report available</p>
                        <p class="text-xs text-slate-500 mt-0.5">Generated on demand</p>
                        <a href="/Leads/@Model.Id/Report" target="_blank"
                            class="mt-1 inline-flex items-center gap-1 text-xs text-sky-400 hover:text-sky-300 transition-colors">
                            <i class="fa-solid fa-arrow-down text-xs"></i>Download hail report
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     FOOTER
══════════════════════════════════════════════════════════════ -->
<footer class="mt-12 border-t border-slate-700/60 bg-slate-900/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-brand/80 rounded flex items-center justify-center">
                <i class="fa-solid fa-house-chimney text-white text-xs"></i>
            </div>
            <span>StormLead Pro &copy; 2026</span>
        </div>
        <div class="flex items-center gap-4 text-xs">
            <a href="/Leads/Saved" class="hover:text-slate-300 transition-colors">
                <i class="fa-solid fa-arrow-left mr-1"></i>Back to Saved Leads
            </a>
            <a href="/Leads/@Model.Id/Report" target="_blank" class="hover:text-slate-300 transition-colors">
                <i class="fa-solid fa-file-pdf mr-1"></i>PDF Report
            </a>
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="~/js/claim-window.js"></script>
<script src="~/js/lead-detail.js"></script>
<script>
function toggleMobileMenu() {
    var menu = document.getElementById('mobileMenu');
    var icon = document.getElementById('mobileMenuIcon');
    if (!menu) return;
    var nowHidden = menu.classList.toggle('hidden');
    icon.className = nowHidden ? 'fa-solid fa-bars text-lg' : 'fa-solid fa-xmark text-lg';
}
</script>
</body>
</html>
