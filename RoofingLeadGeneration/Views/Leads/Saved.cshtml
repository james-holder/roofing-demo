@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saved Leads — StormLead Pro</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy:  { DEFAULT: '#0f172a', 700: '#1e293b', 600: '#334155', 500: '#475569' },
                        brand: { DEFAULT: '#f97316', dark: '#ea6c0a', light: '#fdba74' }
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/saved-leads.css" />
</head>
<body class="min-h-screen">

<!-- Toast -->
<div id="toast">
    <i id="toastIcon" class="fa-solid fa-circle-check"></i>
    <span id="toastMsg"></span>
</div>

<!-- ══════════════════════════════════════════════════════════════
     HEADER
══════════════════════════════════════════════════════════════ -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">

        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-bold tracking-tight">
                Storm<span class="text-brand">Lead</span> Pro
            </span>
        </a>

        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">
                <i class="fa-solid fa-magnifying-glass mr-1 text-xs"></i>Search
            </a>
            <a href="/Leads/Saved" class="text-white font-semibold">
                <i class="fa-solid fa-bookmark mr-1 text-brand text-xs"></i>Saved Leads
            </a>
            <span class="text-slate-600">|</span>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="text-slate-300 text-xs">
                    <i class="fa-solid fa-circle-user mr-1 text-brand"></i>@User.Identity.Name
                </span>
                <a href="/Auth/Logout" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Sign out</a>
            }
            else
            {
                <a href="/Auth/Login" class="px-3 py-1 rounded-full bg-brand/10 text-brand border border-brand/30 text-xs font-semibold hover:bg-brand/20 transition-colors">
                    <i class="fa-solid fa-right-to-bracket mr-1"></i>Sign In
                </a>
            }
        </nav>
    </div>
</header>

<!-- ══════════════════════════════════════════════════════════════
     PAGE HERO
══════════════════════════════════════════════════════════════ -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-wrap items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-extrabold text-white flex items-center gap-2">
                <i class="fa-solid fa-bookmark text-brand"></i>
                Saved Leads
                <span id="heroCount" class="text-base font-normal text-slate-400 ml-1"></span>
            </h1>
            <p class="text-slate-400 text-sm mt-0.5">Manage your pipeline and enrich with homeowner contact info.</p>
        </div>
        <div class="flex items-center gap-2">
            <button id="enrichBtn" onclick="enrichAll()"
                class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-slate-700 hover:bg-slate-600
                       border border-slate-600 text-xs font-semibold text-slate-200 transition shadow"
                title="Fill in owner names from Regrid (requires free Regrid token in appsettings.json)">
                <i class="fa-solid fa-wand-magic-sparkles text-brand"></i>Enrich Owners
            </button>
            <button onclick="exportCSV()"
                class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-slate-700 hover:bg-slate-600
                       border border-slate-600 text-xs font-semibold text-slate-200 transition shadow">
                <i class="fa-solid fa-file-csv text-brand"></i>Export CSV
            </button>
            <a href="/"
                class="flex items-center gap-1.5 px-4 py-2 rounded-xl bg-brand hover:bg-brand-dark
                       text-white text-xs font-semibold transition shadow">
                <i class="fa-solid fa-plus"></i>New Scan
            </a>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TABS
══════════════════════════════════════════════════════════════ -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex gap-0 border-b border-slate-700/60">
        <button id="tabBtnLeads" onclick="switchTab('leads')"
            class="tab-btn active px-5 py-3.5 text-sm font-semibold border-b-2 -mb-px">
            <i class="fa-solid fa-table-list mr-1.5"></i>My Leads
        </button>
        <button id="tabBtnSources" onclick="switchTab('sources')"
            class="tab-btn px-5 py-3.5 text-sm font-semibold border-b-2 -mb-px">
            <i class="fa-solid fa-database mr-1.5"></i>Data Sources
        </button>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: MY LEADS
══════════════════════════════════════════════════════════════ -->
<div id="panelLeads" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    <!-- Filter / search bar -->
    <div class="flex flex-wrap items-center gap-3 mb-4">

        <!-- Risk filters -->
        <div class="flex items-center gap-1.5">
            <button onclick="setFilter('all')" data-f="all"
                class="filter-btn active px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-700 border border-slate-600">
                All <span id="fAll" class="ml-1 opacity-60"></span>
            </button>
            <button onclick="setFilter('High')" data-f="High"
                class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-700 border border-slate-600">
                <span class="text-red-400">● High</span> <span id="fHigh" class="ml-1 opacity-60"></span>
            </button>
            <button onclick="setFilter('Medium')" data-f="Medium"
                class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-700 border border-slate-600">
                <span class="text-orange-400">● Medium</span> <span id="fMedium" class="ml-1 opacity-60"></span>
            </button>
            <button onclick="setFilter('Low')" data-f="Low"
                class="filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-700 border border-slate-600">
                <span class="text-green-400">● Low</span> <span id="fLow" class="ml-1 opacity-60"></span>
            </button>
        </div>

        <!-- Search -->
        <div class="relative flex-1 min-w-[200px] max-w-sm ml-auto">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-xs"></i>
            <input id="searchInput" type="text" placeholder="Search address, owner…"
                oninput="renderTable()"
                class="w-full pl-8 pr-3 py-2 rounded-lg bg-slate-800 border border-slate-600 text-white text-xs
                       placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition" />
        </div>
    </div>

    <!-- Table -->
    <div class="rounded-2xl border border-slate-700/60 shadow-xl bg-slate-800/40 overflow-hidden">
        <div class="overflow-x-auto">
            <table id="leadsTable" class="w-full border-collapse">
                <thead>
                    <tr>
                        <th onclick="sortBy('address')"          class="text-left"   style="min-width:160px"><span class="sort-icon">Address</span></th>
                        <th onclick="sortBy('riskLevel')"        class="text-left"   style="min-width:75px"><span class="sort-icon">Risk</span></th>
                        <th onclick="sortBy('ownerName')"        class="text-left hidden sm:table-cell" style="min-width:120px"><span class="sort-icon">Owner</span></th>
                        <th onclick="sortBy('ownerPhone')"       class="text-left hidden sm:table-cell" style="min-width:110px"><span class="sort-icon">Phone</span></th>
                        <th onclick="sortBy('hailSize')"         class="text-left hidden md:table-cell" style="min-width:80px"><span class="sort-icon">Hail</span></th>
                        <th onclick="sortBy('lastStormDate')"    class="text-left hidden md:table-cell" style="min-width:100px"><span class="sort-icon">Storm Date</span></th>
                        <th onclick="sortBy('estimatedDamage')"  class="text-left hidden lg:table-cell" style="min-width:80px"><span class="sort-icon">Damage</span></th>
                        <th onclick="sortBy('roofAge')"          class="text-left hidden lg:table-cell" style="min-width:75px"><span class="sort-icon">Roof Age</span></th>
                        <th onclick="sortBy('propertyType')"     class="text-left hidden lg:table-cell" style="min-width:80px"><span class="sort-icon">Type</span></th>
                        <th onclick="sortBy('ownerEmail')"       class="text-left hidden xl:table-cell" style="min-width:150px"><span class="sort-icon">Email</span></th>
                        <th class="text-center sticky-actions" style="cursor:default">Actions</th>
                    </tr>
                </thead>
                <tbody id="leadsBody"></tbody>
            </table>
        </div>

        <!-- Loading -->
        <div id="leadsLoading" class="flex items-center justify-center py-14 gap-3 text-slate-400 text-sm">
            <svg class="spinner w-5 h-5" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"
                        stroke-dasharray="60" stroke-dashoffset="20" />
            </svg>
            Loading leads…
        </div>

        <!-- Empty -->
        <div id="leadsEmpty" class="hidden flex flex-col items-center justify-center py-16 text-slate-500 gap-2">
            <i class="fa-solid fa-bookmark text-4xl text-slate-700 mb-1"></i>
            <p class="font-semibold text-slate-400">No saved leads yet</p>
            <p class="text-sm">Go back and scan a neighborhood, then save properties.</p>
            <a href="/" class="mt-3 px-4 py-2 rounded-lg bg-brand text-white text-xs font-semibold hover:bg-brand-dark transition">
                <i class="fa-solid fa-magnifying-glass mr-1"></i>Start a Scan
            </a>
        </div>

        <!-- No-match (filter/search) -->
        <div id="leadsNoMatch" class="hidden flex flex-col items-center justify-center py-14 text-slate-500 gap-2">
            <i class="fa-solid fa-filter text-3xl text-slate-700"></i>
            <p class="text-sm">No leads match this filter or search.</p>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     TAB: DATA SOURCES
══════════════════════════════════════════════════════════════ -->
<div id="panelSources" class="hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    <div class="mb-6 p-5 rounded-2xl bg-brand/10 border border-brand/30">
        <h2 class="text-base font-bold text-brand mb-1">
            <i class="fa-solid fa-lightbulb mr-2"></i>How to make this real data
        </h2>
        <p class="text-slate-300 text-sm leading-relaxed">
            Right now the app generates simulated hail data and leaves owner fields blank. Replacing it with real data
            takes three steps: swap the storm data source, enrich with property owner records, then skip-trace for
            contact info. The services below are what real roofing contractors use. Most have affordable per-record pricing.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">

        <!-- ── Storm & Hail Data ── -->
        <div class="col-span-full">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                <i class="fa-solid fa-cloud-bolt mr-2 text-brand"></i>Step 1 — Replace Simulated Storm Data
            </h3>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">HailTrace</p>
                    <p class="text-xs text-slate-400">hailtrace.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/30 text-xs font-semibold">Recommended</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                Built specifically for roofing contractors. Returns hail history (date, stone size, damage probability)
                for any address. Drop-in replacement for <code class="bg-slate-700 px-1 rounded text-brand">GenerateNearbyProperties()</code>.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                GET hailtrace.com/api/v1/hail?lat=32.7&amp;lng=-96.8&amp;radius=0.5mi
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: ~$0.03–$0.10 per address lookup</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">StormAware</p>
                    <p class="text-xs text-slate-400">stormaware.us</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-blue-500/15 text-blue-400 border border-blue-500/30 text-xs font-semibold">Popular</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                Storm history API with hail size, wind speed, and date of impact per address. Used widely in
                Texas and Midwest roofing markets. Includes a damage severity score.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                GET api.stormaware.us/v2/history?address=...&amp;days=730
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: subscription or per-lookup tiers</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">NOAA NEXRAD</p>
                    <p class="text-xs text-slate-400">ncei.noaa.gov</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-500/30 text-slate-400 border border-slate-600 text-xs font-semibold">Free</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                NOAA's public radar archive. Free but requires significant processing — you'd parse raw
                Level-II radar data yourself. Best for developers who want full control at no cost.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                ncei.noaa.gov/access/search/data-search/nexrad-level-2
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: Free (compute costs apply)</p>
        </div>

        <!-- ── Property & Owner Data ── -->
        <div class="col-span-full mt-4">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                <i class="fa-solid fa-house-user mr-2 text-brand"></i>Step 2 — Get Property Owner Names
            </h3>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">ATTOM Data Solutions</p>
                    <p class="text-xs text-slate-400">attomdata.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/30 text-xs font-semibold">Best Coverage</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                The most comprehensive property database in the US. Returns owner name, purchase date, estimated
                value, mortgage info, and property details for 155M+ properties. Integrates directly with this app's
                <code class="bg-slate-700 px-1 rounded text-brand">PATCH /Leads/{'{id}'}/Owner</code> endpoint.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                GET api.gateway.attomdata.com/propertyapi/v1.0.0/property/detail?address=...
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: ~$0.10–$0.30/record, monthly plans available</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">Regrid Parcel Data</p>
                    <p class="text-xs text-slate-400">regrid.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-blue-500/15 text-blue-400 border border-blue-500/30 text-xs font-semibold">Free Tier</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                Aggregates county assessor data for all 50 states. Returns the legal owner name (as recorded
                at the county). Free tier available for small volume — ideal for testing before committing to ATTOM.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                GET app.regrid.com/api/v1/parcel?lat=32.7&amp;lon=-96.8&amp;token=...
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: Free tier, then $0.01–$0.05/lookup</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">County Assessor Portals</p>
                    <p class="text-xs text-slate-400">Public records</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-500/30 text-slate-400 border border-slate-600 text-xs font-semibold">Free</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed">
                Every county publishes property ownership as public record. Most have bulk download files
                (CSV/XML) updated annually. For a single market, scraping or downloading the county file
                once can cover all your leads for free. Search "<em>your county</em> property tax records open data".
            </p>
        </div>

        <!-- ── Skip Tracing / Contact Info ── -->
        <div class="col-span-full mt-4">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                <i class="fa-solid fa-phone mr-2 text-brand"></i>Step 3 — Find Phone &amp; Email (Skip Tracing)
            </h3>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">BatchSkipTracing</p>
                    <p class="text-xs text-slate-400">batchskiptracing.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/30 text-xs font-semibold">Recommended</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                Purpose-built for contractors and real estate investors. Upload a CSV of addresses, get back
                owner name + best phone + email within minutes. Extremely affordable and widely used in roofing.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                POST batchskiptracing.com/api/v2/skip<br/>
                Body: [{"{ address, city, state, zip }"}]
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: ~$0.12/record — bulk discounts available</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">Whitepages Pro</p>
                    <p class="text-xs text-slate-400">pro.whitepages.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-blue-500/15 text-blue-400 border border-blue-500/30 text-xs font-semibold">Per Lookup</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed mb-3">
                Reverse address lookup that returns owner name and phone numbers. High match rate and
                real-time results. Good for one-off enrichment when you don't need bulk processing.
            </p>
            <div class="bg-slate-900 rounded-lg p-3 text-xs font-mono text-slate-400">
                GET proapi.whitepages.com/3.0/place.json?address.street_line=...&amp;api_key=...
            </div>
            <p class="text-slate-500 text-xs mt-2">Pricing: ~$0.25–$0.50/lookup</p>
        </div>

        <div class="source-card rounded-2xl bg-slate-800/60 border border-slate-700/60 p-5">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <p class="font-bold text-white text-sm">Melissa Data</p>
                    <p class="text-xs text-slate-400">melissa.com</p>
                </div>
                <span class="px-2 py-0.5 rounded-full bg-slate-500/30 text-slate-400 border border-slate-600 text-xs font-semibold">Enterprise</span>
            </div>
            <p class="text-slate-300 text-xs leading-relaxed">
                Address verification + contact enrichment in one API. Returns owner name, phone, email,
                and address corrections. Well-suited if you also want to clean/validate the addresses
                coming in from the Google autocomplete.
            </p>
        </div>

        <!-- ── Integration roadmap ── -->
        <div class="col-span-full mt-4">
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">
                <i class="fa-solid fa-code-branch mr-2 text-brand"></i>Integration Roadmap
            </h3>
            <div class="rounded-2xl bg-slate-800/60 border border-slate-700/60 p-6">
                <ol class="space-y-4">
                    <li class="flex gap-4">
                        <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand/20 border border-brand/40 flex items-center justify-center text-brand text-xs font-bold">1</div>
                        <div>
                            <p class="text-white text-sm font-semibold">Replace <code class="bg-slate-700 px-1 rounded text-brand text-xs">GenerateNearbyProperties()</code> in RoofHealthController.cs</p>
                            <p class="text-slate-400 text-xs mt-0.5">Call HailTrace or StormAware with the geocoded lat/lng. Map their response to the existing <code class="bg-slate-700 px-1 rounded text-brand text-xs">PropertyRecord</code> shape — the rest of the app just works.</p>
                        </div>
                    </li>
                    <li class="flex gap-4">
                        <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand/20 border border-brand/40 flex items-center justify-center text-brand text-xs font-bold">2</div>
                        <div>
                            <p class="text-white text-sm font-semibold">Add background enrichment after a lead is saved</p>
                            <p class="text-slate-400 text-xs mt-0.5">In <code class="bg-slate-700 px-1 rounded text-brand text-xs">LeadsController.Save()</code>, after inserting, enqueue a background job to call ATTOM or Regrid for the owner name and store it via <code class="bg-slate-700 px-1 rounded text-brand text-xs">PATCH /Leads/{'{id}'}/Owner</code>.</p>
                        </div>
                    </li>
                    <li class="flex gap-4">
