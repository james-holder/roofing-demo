@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StormLead Pro — Roofing Leads Powered by Real Hail Data</title>
    <meta name="description" content="Find storm-damaged roofs before your competition. StormLead Pro combines real NOAA hail data with actual property addresses to surface high-probability roofing leads in seconds." />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { brand: '#f97316' },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        html { scroll-behavior: smooth; }
        .gradient-text {
            background: linear-gradient(135deg, #f97316, #fb923c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-glow {
            background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(249,115,22,0.15), transparent);
        }
        .card-hover {
            transition: transform 0.2s ease, border-color 0.2s ease;
        }
        .card-hover:hover {
            transform: translateY(-2px);
            border-color: rgba(249,115,22,0.4);
        }
        .pricing-popular {
            position: relative;
        }
        .pricing-popular::before {
            content: 'MOST POPULAR';
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: #f97316;
            color: white;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.1em;
            padding: 3px 12px;
            border-radius: 999px;
        }
    </style>
</head>
<body class="bg-slate-950 text-white font-sans antialiased">

    <!-- ── Nav ─────────────────────────────────────────────────────────── -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/60 backdrop-blur-md bg-slate-950/80">
        <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-lg bg-brand flex items-center justify-center">
                    <i class="fa-solid fa-cloud-bolt text-white text-sm"></i>
                </div>
                <span class="font-bold text-white text-lg tracking-tight">StormLead <span class="text-brand">Pro</span></span>
            </div>
            <div class="flex items-center gap-4">
                <a href="#pricing" class="text-sm text-slate-400 hover:text-white transition hidden sm:block">Pricing</a>
                <a href="/Help"    class="text-sm text-slate-400 hover:text-white transition hidden sm:block">Help</a>
                <a href="/Auth/Login" class="text-sm text-slate-400 hover:text-white transition">Log in</a>
                <a href="/Auth/Login" class="text-sm bg-brand hover:bg-orange-400 text-white font-semibold px-4 py-2 rounded-lg transition">
                    Get Started Free
                </a>
            </div>
        </div>
    </nav>

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <section class="hero-glow pt-32 pb-24 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 bg-slate-800/80 border border-slate-700 rounded-full px-4 py-1.5 text-sm text-slate-300 mb-8">
                <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                Powered by real NOAA hail data — no estimates
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight mb-6">
                Find storm-damaged roofs<br />
                <span class="gradient-text">before your competition does.</span>
            </h1>

            <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
                StormLead Pro scans any neighborhood using real NOAA hail records and actual property addresses to surface your highest-probability roofing leads — in seconds, not hours.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/Auth/Login"
                   class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-brand hover:bg-orange-400 text-white font-bold text-base px-8 py-4 rounded-xl transition shadow-lg shadow-orange-500/20">
                    <i class="fa-solid fa-bolt"></i>
                    Start for Free — No Credit Card
                </a>
                <a href="/Auth/DemoLogin"
                   class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold text-base px-8 py-4 rounded-xl border border-slate-700 transition">
                    <i class="fa-solid fa-play text-sm"></i>
                    Try the live demo
                </a>
            </div>
            <p class="text-xs text-slate-600 mt-4">Demo uses a shared account — your data may be visible to others.</p>
        </div>
    </section>

    <!-- ── Trust bar ─────────────────────────────────────────────────────── -->
    <div class="border-y border-slate-800/60 bg-slate-900/50 py-5 px-6">
        <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-8 text-sm text-slate-500">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-cloud-sun-rain text-sky-400"></i>
                <span>Real NOAA SWDI hail data</span>
            </div>
            <div class="w-px h-4 bg-slate-700 hidden sm:block"></div>
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-map-location-dot text-green-400"></i>
                <span>OpenStreetMap addresses</span>
            </div>
            <div class="w-px h-4 bg-slate-700 hidden sm:block"></div>
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-file-lines text-violet-400"></i>
                <span>Regrid parcel records</span>
            </div>
            <div class="w-px h-4 bg-slate-700 hidden sm:block"></div>
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-shield-halved text-brand"></i>
                <span>No fake data, ever</span>
            </div>
        </div>
    </div>

    <!-- ── How it works ──────────────────────────────────────────────────── -->
    <section id="how-it-works" class="py-24 px-6">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16">
                <p class="text-brand font-semibold text-sm uppercase tracking-widest mb-3">How it works</p>
                <h2 class="text-3xl sm:text-4xl font-black">From address to lead list in under 60 seconds.</h2>
            </div>

            <div class="grid sm:grid-cols-3 gap-8">
                <div class="relative">
                    <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/30 flex items-center justify-center text-brand font-black text-lg mb-5">1</div>
                    <h3 class="text-lg font-bold text-white mb-2">Scan a neighborhood</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Enter any address and choose a radius. We pull every residential property from OpenStreetMap and cross-reference each one against NOAA hail records.</p>
                    <div class="hidden sm:block absolute top-5 left-full w-full h-px border-t border-dashed border-slate-700 -translate-x-4"></div>
                </div>
                <div class="relative">
                    <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/30 flex items-center justify-center text-brand font-black text-lg mb-5">2</div>
                    <h3 class="text-lg font-bold text-white mb-2">Review risk scores</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Every property gets a High / Medium / Low risk rating based on real hail size and storm recency. High-risk leads rise to the top automatically.</p>
                    <div class="hidden sm:block absolute top-5 left-full w-full h-px border-t border-dashed border-slate-700 -translate-x-4"></div>
                </div>
                <div>
                    <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/30 flex items-center justify-center text-brand font-black text-lg mb-5">3</div>
                    <h3 class="text-lg font-bold text-white mb-2">Save, enrich & contact</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Save your best leads, then hit the enrich button to pull the owner's name and contact info. Export to CSV or start dialing.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Features ──────────────────────────────────────────────────────── -->
    <section class="py-24 px-6 bg-slate-900/40 border-y border-slate-800/60">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16">
                <p class="text-brand font-semibold text-sm uppercase tracking-widest mb-3">Features</p>
                <h2 class="text-3xl sm:text-4xl font-black">Built for roofers, not data scientists.</h2>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-cloud-showers-heavy text-sky-400"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">Real NOAA hail data</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Every risk score is backed by actual NEXRAD radar hail signatures — not estimates or ZIP-code averages.</p>
                </div>

                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-location-dot text-green-400"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">Actual property addresses</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Real streets, real house numbers from OpenStreetMap — no fabricated addresses that lead nowhere.</p>
                </div>

                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-brand/10 border border-brand/20 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-bolt text-brand"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">One-click owner lookup</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Pull owner name, phone, and email from public parcel records with a single click — no manual skip tracing.</p>
                </div>

                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-map text-violet-400"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">Interactive map view</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Every lead is pinned on a live map so you can plan a canvassing route or visualize storm damage concentration.</p>
                </div>

                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-file-csv text-orange-400"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">CSV export</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Export your lead list anytime — drop it straight into your CRM, dialers, or direct mail platform.</p>
                </div>

                <div class="card-hover bg-slate-800/60 border border-slate-700/60 rounded-2xl p-6">
                    <div class="w-10 h-10 rounded-xl bg-slate-600/40 border border-slate-600/40 flex items-center justify-center mb-4">
                        <i class="fa-solid fa-sliders text-slate-400"></i>
                    </div>
                    <h3 class="font-bold text-white mb-2">Filter &amp; sort by risk</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">Sort by High / Medium / Low risk, search by owner name or address, and focus your time on the best opportunities first.</p>
                </div>
            </div>
        </div>
    </section>

