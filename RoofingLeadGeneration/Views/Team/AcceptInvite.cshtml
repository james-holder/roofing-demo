@{
    var error      = ViewBag.Error      as string;
    var success    = (bool)(ViewBag.Success    ?? false);
    var needsLogin = (bool)(ViewBag.NeedsLogin ?? false);
    var orgName    = ViewBag.OrgName    as string ?? "your team";
    var orgRole    = ViewBag.OrgRole    as string ?? "rep";
    var inviteEmail= ViewBag.InviteEmail as string ?? "";
    var token      = ViewBag.Token      as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Team Invitation — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                brand: '#f97316',
                navy:  { DEFAULT: '#0f172a', 700: '#1e293b', 600: '#334155', 500: '#475569' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-navy text-slate-100 min-h-screen flex items-center justify-center px-4">

<div class="w-full max-w-md">

    <!-- Logo -->
    <div class="flex items-center justify-center gap-2.5 mb-8">
        <div class="w-10 h-10 bg-brand rounded-xl flex items-center justify-center shadow-lg">
            <i class="fa-solid fa-house-chimney text-white"></i>
        </div>
        <span class="text-xl font-extrabold tracking-tight">
            Storm<span class="text-brand">Lead</span> Pro
        </span>
    </div>

    <div class="bg-navy-700 border border-slate-700/60 rounded-2xl overflow-hidden shadow-2xl">

        @if (error != null) {
        <!-- Error state -->
        <div class="p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-red-900/30 border border-red-700/40 flex items-center justify-center mx-auto mb-5">
                <i class="fa-solid fa-circle-xmark text-red-400 text-2xl"></i>
            </div>
            <h1 class="text-xl font-bold text-white mb-2">Invitation Invalid</h1>
            <p class="text-slate-400 text-sm mb-6">@error</p>
            <a href="/" class="inline-block px-5 py-2.5 rounded-xl bg-slate-700 hover:bg-slate-600 text-white text-sm font-medium transition">
                Go to Home
            </a>
        </div>

        } else if (success) {
        <!-- Success state -->
        <div class="p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-green-900/30 border border-green-700/40 flex items-center justify-center mx-auto mb-5">
                <i class="fa-solid fa-circle-check text-green-400 text-2xl"></i>
            </div>
            <h1 class="text-xl font-bold text-white mb-2">Welcome to the team!</h1>
            <p class="text-slate-400 text-sm mb-2">
                You've joined <span class="text-white font-semibold">@orgName</span>
                as a <span class="text-brand font-semibold capitalize">@orgRole</span>.
            </p>
            <p class="text-slate-500 text-xs mb-6">You now have access to your team's leads and data.</p>
            <a href="/" class="inline-block px-6 py-2.5 rounded-xl bg-brand hover:bg-brand/90 text-white text-sm font-semibold transition">
                <i class="fa-solid fa-magnifying-glass mr-1.5"></i>Start Searching
            </a>
        </div>

        } else if (needsLogin) {
        <!-- Needs login state -->
        <div class="bg-brand/10 border-b border-brand/20 px-6 py-4 text-center">
            <span class="text-brand font-semibold text-sm">
                <i class="fa-solid fa-envelope-open-text mr-1.5"></i>Team Invitation
            </span>
        </div>
        <div class="p-8">
            <h1 class="text-xl font-bold text-white mb-2 text-center">You've been invited</h1>
            <p class="text-slate-400 text-sm text-center mb-6">
                Sign in to join <span class="text-white font-semibold">@orgName</span>.
                @if (!string.IsNullOrEmpty(inviteEmail)) {
                    <span class="block mt-1 text-slate-500 text-xs">Invitation sent to @inviteEmail</span>
                }
            </p>
            <div class="space-y-3">
                <a href="/Auth/Login?returnUrl=@Uri.EscapeDataString($"/Team/Accept/{token}")"
                   class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-xl bg-brand hover:bg-brand/90 text-white text-sm font-semibold transition">
                    <i class="fa-solid fa-right-to-bracket"></i>Sign In to Accept
                </a>
                <p class="text-center text-slate-600 text-xs">
                    Don't have an account? Sign up with Google or Microsoft on the login page.
                </p>
            </div>
        </div>

        }
    </div>

    <p class="text-center text-slate-600 text-xs mt-6">
        StormLead Pro — Roofing Lead Generation
    </p>
</div>

</body>
</html>
