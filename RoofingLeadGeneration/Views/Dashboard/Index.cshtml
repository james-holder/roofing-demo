@{
    Layout = null;
    var userName        = ViewBag.UserName        as string ?? "Guest";
    var isAdmin         = ViewBag.IsAdmin         is true;
    var totalLeads      = (long)(ViewBag.TotalLeads      ?? 0L);
    var leadsThisMonth  = (long)(ViewBag.LeadsThisMonth  ?? 0L);
    var totalEnrich     = (long)(ViewBag.TotalEnrich     ?? 0L);
    var enrichThisMonth = (long)(ViewBag.EnrichThisMonth ?? 0L);
    var recentLeads     = ViewBag.RecentLeads     as List<(string Address, string Risk, string Hail, string SavedAt)> ?? new();
    var recentEnrich    = ViewBag.RecentEnrich    as List<(string Address, string Status, string CreatedAt)>          ?? new();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                navy:  { DEFAULT: '#0f172a', 700: '#1e293b', 600: '#334155', 500: '#475569' },
                brand: { DEFAULT: '#f97316', dark: '#ea6c0a', light: '#fdba74' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="min-h-screen">

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-extrabold tracking-tight">Storm<span class="text-brand">Lead</span> Pro</span>
        </a>
        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">Search</a>
            <a href="/Leads/Saved" class="hover:text-white transition-colors">Saved Leads</a>
            <a href="/Dashboard" class="text-white font-semibold">Dashboard</a>
            <a href="/Alerts" class="hover:text-white transition-colors">
                <i class="fa-solid fa-bell mr-1 text-xs"></i>Alerts
            </a>
            <a href="/Help" class="hover:text-white transition-colors">
                <i class="fa-solid fa-circle-question mr-1 text-xs"></i>Help
            </a>
            @if (isAdmin) {
                <a href="/Admin" class="text-orange-400 hover:text-orange-300 transition-colors">
                    <i class="fa-solid fa-shield-halved mr-1 text-xs"></i>Admin
                </a>
            }
            <span class="text-slate-600">|</span>
            @if (User.Identity?.IsAuthenticated == true) {
                <span class="text-slate-300 text-xs"><i class="fa-solid fa-circle-user mr-1 text-brand"></i>@User.Identity.Name</span>
                <a href="/Auth/Logout" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Sign out</a>
            } else {
                <a href="/Auth/Login" class="px-3 py-1 rounded-full bg-brand/10 text-brand border border-brand/30 text-xs font-semibold hover:bg-brand/20 transition-colors">
                    <i class="fa-solid fa-right-to-bracket mr-1"></i>Sign In
                </a>
            }
        </nav>

        <!-- Hamburger (mobile only) -->
        <button id="mobileMenuBtn" onclick="toggleMobileMenu()"
            class="lg:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-700/60 transition-colors">
            <i id="mobileMenuIcon" class="fa-solid fa-bars text-lg"></i>
        </button>
    </div>

    <!-- Mobile nav drawer -->
    <div id="mobileMenu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-[#0f172a] border-t border-slate-700/60 shadow-2xl z-50 px-4 py-3 flex flex-col gap-1">
        <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-magnifying-glass w-4 text-center text-xs"></i>Search
        </a>
        <a href="/Leads/Saved" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-bookmark w-4 text-center text-xs"></i>Saved Leads
        </a>
        <a href="/Dashboard" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-slate-700/60 text-white font-semibold text-sm">
            <i class="fa-solid fa-chart-bar text-brand w-4 text-center text-xs"></i>Dashboard
        </a>
        <a href="/Alerts" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-bell w-4 text-center text-xs"></i>Alerts
        </a>
        <a href="/Help" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-circle-question w-4 text-center text-xs"></i>Help
        </a>
        <div class="border-t border-slate-700/60 my-1"></div>
        @if (User.Identity?.IsAuthenticated == true) {
            <div class="flex items-center justify-between px-3 py-2">
                <span class="text-slate-300 text-sm">
                    <i class="fa-solid fa-circle-user mr-2 text-brand"></i>@User.Identity.Name
                </span>
                <a href="/Auth/Logout" class="text-xs text-slate-500 hover:text-slate-300 transition-colors px-3 py-1.5 rounded-lg hover:bg-slate-700/60">Sign out</a>
            </div>
        } else {
            <a href="/Auth/Login" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-brand/10 border border-brand/30 text-brand text-sm font-semibold">
                <i class="fa-solid fa-right-to-bracket"></i>Sign In
            </a>
        }
    </div>
</header>

<!-- Page hero -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-2xl font-extrabold text-white">
            <i class="fa-solid fa-gauge-high text-brand mr-2"></i>Dashboard
        </h1>
        <p class="text-slate-400 text-sm mt-0.5">Welcome back, @userName</p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Stats row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Total Leads</p>
            <p class="text-3xl font-extrabold text-white">@totalLeads</p>
            <p class="text-xs text-slate-500 mt-1">all time</p>
        </div>

        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Leads This Month</p>
            <p class="text-3xl font-extrabold text-brand">@leadsThisMonth</p>
            <p class="text-xs text-slate-500 mt-1">current billing period</p>
        </div>

        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Enrichments</p>
            <p class="text-3xl font-extrabold text-white">@enrichThisMonth</p>
            <p class="text-xs text-slate-500 mt-1">this month · @totalEnrich total</p>
        </div>

        <div class="stat-card border-brand/30">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Contact Lookup</p>
            <p class="text-sm font-bold text-brand mt-2">Coming soon</p>
            <p class="text-xs text-slate-500 mt-1">BatchSkipTracing integration</p>
        </div>

    </div>

    <!-- Two-column: Recent Leads + Recent Enrichments -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Recent leads -->
        <div class="rounded-2xl border border-slate-700/60 bg-slate-800/40 overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-700/60 flex items-center justify-between">
                <h2 class="text-sm font-bold text-white">
                    <i class="fa-solid fa-map-pin text-brand mr-2"></i>Recent Leads
                </h2>
                <a href="/Leads/Saved" class="text-xs text-brand hover:text-orange-300 transition-colors">View all →</a>
            </div>
            @if (recentLeads.Any())
            {
                <table class="w-full">
                    <thead>
                        <tr>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60">Address</th>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60">Risk</th>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60 hidden sm:table-cell">Hail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in recentLeads)
                        {
                            var badgeClass = lead.Risk == "High" ? "badge-high" : lead.Risk == "Medium" ? "badge-medium" : "badge-low";
                            <tr class="border-b border-slate-700/40 hover:bg-slate-700/20 transition-colors">
                                <td class="px-5 py-3 text-xs text-white max-w-[200px]">
                                    <span class="block truncate" title="@lead.Address">@lead.Address</span>
                                </td>
                                <td class="px-5 py-3">
                                    <span class="@badgeClass px-2 py-0.5 rounded-full text-xs font-bold">@lead.Risk</span>
                                </td>
                                <td class="px-5 py-3 text-xs text-slate-400 hidden sm:table-cell">@lead.Hail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-12 text-slate-500 gap-2">
                    <i class="fa-solid fa-map-pin text-3xl text-slate-700"></i>
                    <p class="text-sm">No leads yet — <a href="/" class="text-brand hover:underline">start a scan</a></p>
                </div>
            }
        </div>

        <!-- Recent enrichments -->
        <div class="rounded-2xl border border-slate-700/60 bg-slate-800/40 overflow-hidden">
            <div class="px-5 py-4 border-b border-slate-700/60 flex items-center justify-between">
                <h2 class="text-sm font-bold text-white">
                    <i class="fa-solid fa-bolt text-brand mr-2"></i>Recent Enrichments
                </h2>
                <span class="text-xs text-slate-500">per-record contact lookup</span>
            </div>
            @if (recentEnrich.Any())
            {
                <table class="w-full">
                    <thead>
                        <tr>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60">Address</th>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60">Status</th>
                            <th class="text-left text-xs font-semibold text-slate-500 uppercase px-5 py-3 bg-slate-800/60 hidden sm:table-cell">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in recentEnrich)
                        {
                            var statusColor = e.Status == "completed" ? "text-green-400" : e.Status == "failed" ? "text-red-400" : "text-slate-400";
                            <tr class="border-b border-slate-700/40 hover:bg-slate-700/20 transition-colors">
                                <td class="px-5 py-3 text-xs text-white max-w-[200px]">
                                    <span class="block truncate" title="@e.Address">@e.Address</span>
                                </td>
                                <td class="px-5 py-3 text-xs @statusColor font-semibold">@e.Status</td>
                                <td class="px-5 py-3 text-xs text-slate-400 hidden sm:table-cell whitespace-nowrap">@e.CreatedAt[..10]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-12 text-slate-500 gap-2">
                    <i class="fa-solid fa-bolt text-3xl text-slate-700"></i>
                    <p class="text-sm">No enrichments yet</p>
                </div>
            }
        </div>

    </div><!-- /grid -->

</div><!-- /max-w-7xl -->

<!-- Footer -->
<footer class="mt-12 border-t border-slate-700/60 bg-slate-900/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-brand/80 rounded flex items-center justify-center">
                <i class="fa-solid fa-house-chimney text-white text-xs"></i>
            </div>
            <span>StormLead Pro &copy; 2026</span>
        </div>
        <a href="/Leads/Saved" class="text-brand hover:text-orange-300 transi