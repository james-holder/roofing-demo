{
  // ── Admin access ────────────────────────────────────────────────────────
  // Email address that gets access to /Admin. Change this to your own address.
  "AdminEmail": "jaholder78@gmail.com",

  // ── DNC.com (National Do Not Call Registry scrub) ──────────────────────
  // Sign up at https://www.dnc.com — ~$99/year flat fee for TX+OK area codes.
  // API docs: https://www.dnc.com/api  — GET /v2/scrub?phone={number}&apiKey={key}
  // Leave ApiKey blank to skip DNC scrubbing (numbers will still be checked
  // against the internal suppression list, but NOT the federal registry).
  "DncCom": {
    "ApiKey": ""
  },

  // ── Twilio (Lead Gen SMS) ───────────────────────────────────────────────
  // Sign up at https://twilio.com — free trial includes a phone number + credits.
  // AccountSid and AuthToken are on your Twilio Console dashboard.
  // FromNumber must be a Twilio number in E.164 format: +1XXXXXXXXXX
  "Twilio": {
    "AccountSid":  "",
    "AuthToken":   "",
    "FromNumber":  ""
  },

  // ── Feature flags ───────────────────────────────────────────────────────
  "FeatureFlags": {
    "HailSwathPolygons": false // convex-hull size-banded swath overlay in Storm Explorer
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ── Google Maps API key ────────────────────────────────────────────────
  // Used server-side (geocoding, reverse-geocode grid) and in the frontend map.
  // Restriction: set to "None" (or IP-restricted) — HTTP-referrer keys won't
  // work for server-side calls.
  "GoogleMaps": {
    "ApiKey": ""
  },

  // ── Free data source API keys ──────────────────────────────────────────
  // Regrid (property owner names): sign up free at https://app.regrid.com
  //   Free Starter plan = 25 lookups/day. Paste your token below.
  //   Leave blank to skip owner-name enrichment (app still works fully).
  "Regrid": {
    "Token": ""
  },

  // ── Tomorrow.io (hail and weather history) ────────────────────────────
  // Sign up free at https://app.tomorrow.io — 500 req/day free, 5yr history.
  // Fills the NOAA 120-day radar lag gap with near-real-time storm data.
  "TomorrowIo": {
    "ApiKey": ""
  },

  // ── Auth providers ────────────────────────────────────────────────────────
  // Leave blank during demo phase — no login is required yet.
  // Fill in before going live to enable Google / Microsoft sign-in.
  //
  // Google:    https://console.cloud.google.com  → APIs & Services → Credentials
  //            Authorised redirect URI: https://yourdomain/signin-google
  //
  // Microsoft: https://portal.azure.com  → Azure Active Directory → App registrations
  //            Redirect URI: https://yourdomain/signin-microsoft

  // ── BatchSkipTracing (contact enrichment) ─────────────────────────────────
  // Sign up at https://batchskiptracing.com — pay-per-record, ~$0.12/lookup
  // Paste your API key below to enable the lightning bolt button on each lead.
  "BatchSkipTracing": {
    "ApiKey": ""
  },

  // ── Whitepages Pro (contact enrichment — phone + email) ───────────────────
  // Sign up at https://pro.whitepages.com — ~$0.22/record on the 1000/mo plan
  // Paste your API key below. When set, the Enrich button will call Whitepages
  // after Regrid to fill in phone + email.
  "WhitepagesPro": {
    "ApiKey": ""
  },

  // ── Email / SMTP (storm alert emails) ────────────────────────────────────
  // Works with any SMTP server. Port 587 = STARTTLS, 465 = SSL, 25 = plain.
  // Leave SmtpHost blank to disable email sending (app still works fully).
  "Email": {
    "SmtpHost": "",
    "SmtpPort": "587",
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "StormLead Pro"
  },

  "Auth": {
    "DemoEnabled": "false",
    "DemoEmail": "",
    "DemoPassword": "",
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": ""
    }
  }
  // ── Notes on other data sources ────────────────────────────────────────
  // OpenStreetMap Overpass API (real nearby addresses):  No key needed.
  // NOAA SWDI hail API        (real storm history):      No key needed.
  // Google Maps               (geocoding + autocomplete): Already configured
  //                            in RoofHealthController.cs and Index.cshtml.
}
